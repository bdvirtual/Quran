{
  "surah_no": 107,
  "ar_name": "الماعون",
  "bn_name": "আল-মাউন",
  "en_name": "Al-Ma'un",
  "ayahs": [
    {
      "ayah_no": 1,
      "arabic": "اَرَءَیۡتَ  الَّذِیۡ یُکَذِّبُ بِالدِّیۡنِ ؕ﴿۱﴾ ",
      "bn": "তুমি কি তাকে দেখেছ, যে দ্বীনকে মিথ্যাপ্রতিপন্ন করে?",
      "words": []
    },
    {
      "ayah_no": 2,
      "arabic": "فَذٰلِکَ الَّذِیۡ یَدُعُّ  الۡیَتِیۡمَ ۙ﴿۲﴾ ",
      "bn": "তারপর সে—ই, যে ইয়াতিমকে কঠোরভাবে তাড়িয়ে দেয় ",
      "words": []
    },
    {
      "ayah_no": 3,
      "arabic": "وَ لَا یَحُضُّ عَلٰی طَعَامِ الۡمِسۡکِیۡنِ ؕ﴿۳﴾ ",
      "bn": "এবং মিসকিনকে খাদ্যদানের ব্যাপারে উদ্বুদ্ধ করে না। ",
      "words": []
    },
    {
      "ayah_no": 4,
      "arabic": "فَوَیۡلٌ  لِّلۡمُصَلِّیۡنَ ۙ﴿۴﴾ ",
      "bn": "সুতরাং ওয়াইল, মুসল্লিদের জন্য,",
      "words": []
    },
    {
      "ayah_no": 5,
      "arabic": "الَّذِیۡنَ ہُمۡ عَنۡ صَلَاتِہِمۡ سَاہُوۡنَ ۙ﴿۵﴾ ",
      "bn": "তারা, যারা তাদের সলাতের ব্যাপারে উদাসীন।  ",
      "words": []
    },
    {
      "ayah_no": 6,
      "arabic": "الَّذِیۡنَ ہُمۡ  یُرَآءُوۡنَ ۙ﴿۶﴾ ",
      "bn": "তারা, যারা লোক দেখিয়ে বেড়ায়।",
      "words": []
    },
    {
      "ayah_no": 7,
      "arabic": "وَ یَمۡنَعُوۡنَ الۡمَاعُوۡنَ ٪﴿۷﴾",
      "bn": "এবং নিত্য ব্যবহার্য জিনিসের ক্ষেত্রে কার্পণ্য করে।",
      "words": []
    }
  ]
}