{
  "surah_no": 86,
  "ar_name": "الطارق",
  "bn_name": "আত-তারিক",
  "en_name": "At-Tariq",
  "ayahs": [
    {
      "ayah_no": 1,
      "arabic": "وَ السَّمَآءِ  وَ الطَّارِقِ ۙ﴿۱﴾ ",
      "bn": "শপথ আকাশের, শপথ কড়াঘাতকারীর।",
      "words": []
    },
    {
      "ayah_no": 2,
      "arabic": "وَ مَاۤ  اَدۡرٰىکَ مَا الطَّارِقُ ۙ﴿۲﴾ ",
      "bn": "আর কিসে তোমাকে জানাবে কড়াঘাতকারী কী ?",
      "words": []
    },
    {
      "ayah_no": 3,
      "arabic": "النَّجۡمُ الثَّاقِبُ ۙ﴿۳﴾ ",
      "bn": "উজ্জ্বল নক্ষত্র।",
      "words": []
    },
    {
      "ayah_no": 4,
      "arabic": "اِنۡ کُلُّ نَفۡسٍ لَّمَّا عَلَیۡہَا حَافِظٌ ؕ﴿۴﴾ ",
      "bn": "এমন কোনো প্রাণ নেই, যার উপর সংরক্ষক নেই।",
      "words": []
    },
    {
      "ayah_no": 5,
      "arabic": "فَلۡیَنۡظُرِ الۡاِنۡسَانُ مِمَّ خُلِقَ ؕ﴿۵﴾ ",
      "bn": "সুতরাং মানুষ যেন লক্ষ করে, কিসের থেকে তাকে সৃষ্টি করা হয়েছে!",
      "words": []
    },
    {
      "ayah_no": 6,
      "arabic": "خُلِقَ مِنۡ مَّآءٍ  دَافِقٍ ۙ﴿۶﴾ ",
      "bn": "সবেগে নির্গত পানি থেকে তাকে সৃষ্টি করা হয়েছে,",
      "words": []
    },
    {
      "ayah_no": 7,
      "arabic": "یَّخۡرُجُ مِنۡۢ بَیۡنِ الصُّلۡبِ وَ التَّرَآئِبِ ؕ﴿۷﴾ ",
      "bn": "যা মেরুদণ্ডের ও পাঁজরের মাঝ থেকে বের হয়।",
      "words": []
    },
    {
      "ayah_no": 8,
      "arabic": "اِنَّہٗ  عَلٰی رَجۡعِہٖ لَقَادِرٌ ؕ﴿۸﴾ ",
      "bn": "নিশ্চয়ই তিনি তার প্রত্যাবর্তনের ব্যাপারে অবশ্যই সক্ষম।",
      "words": []
    },
    {
      "ayah_no": 9,
      "arabic": "یَوۡمَ تُبۡلَی السَّرَآئِرُ ۙ﴿۹﴾ ",
      "bn": "যেদিন গোপন বিষয়সমূহের পরীক্ষা করা হবে।",
      "words": []
    },
    {
      "ayah_no": 10,
      "arabic": "فَمَا لَہٗ  مِنۡ قُوَّۃٍ  وَّ لَا  نَاصِرٍ ﴿ؕ۱۰﴾ ",
      "bn": "তখন তার জন্য নাই কোনো শক্তি আর না কোনো সাহায্যকারী।",
      "words": []
    },
    {
      "ayah_no": 11,
      "arabic": "وَ السَّمَآءِ  ذَاتِ الرَّجۡعِ ﴿ۙ۱۱﴾ ",
      "bn": "শপথ! চক্রশীলের অধিকারী আকাশের।",
      "words": []
    },
    {
      "ayah_no": 12,
      "arabic": "وَ الۡاَرۡضِ ذَاتِ الصَّدۡعِ ﴿ۙ۱۲﴾ ",
      "bn": "শপথ! ফাটলবিশিষ্ট ভূমির।",
      "words": []
    },
    {
      "ayah_no": 13,
      "arabic": "اِنَّہٗ  لَقَوۡلٌ  فَصۡلٌ ﴿ۙ۱۳﴾ ",
      "bn": "নিশ্চয়ই সেটা অবশ্যই মীমাংসাসূচক বাণী।",
      "words": []
    },
    {
      "ayah_no": 14,
      "arabic": "وَّ مَا ہُوَ  بِالۡہَزۡلِ ﴿ؕ۱۴﴾ ",
      "bn": "আর তা নয় উপহাস।",
      "words": []
    },
    {
      "ayah_no": 15,
      "arabic": "اِنَّہُمۡ یَکِیۡدُوۡنَ  کَیۡدًا ﴿ۙ۱۵﴾ ",
      "bn": "নিশ্চয়ই তারা কৌশল করছে, চরম কৌশল।",
      "words": []
    },
    {
      "ayah_no": 16,
      "arabic": "وَّ اَکِیۡدُ  کَیۡدًا ﴿ۚۖ۱۶﴾ ",
      "bn": "আর আমি কৌশল করছি, নিপুণ কৌশল।",
      "words": []
    },
    {
      "ayah_no": 17,
      "arabic": "فَمَہِّلِ الۡکٰفِرِیۡنَ  اَمۡہِلۡہُمۡ رُوَیۡدًا ﴿٪۱۷﴾ ",
      "bn": "সুতরাং কাফিরদের সুযোগ দাও। তাদের সাময়িক অবকাশ দাও।",
      "words": []
    }
  ]
}