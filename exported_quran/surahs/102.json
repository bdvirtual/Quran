{
  "surah_no": 102,
  "ar_name": "التكاثر",
  "bn_name": "আত-তাকাসুর",
  "en_name": "At-Takathur",
  "ayahs": [
    {
      "ayah_no": 1,
      "arabic": "اَلۡہٰىکُمُ  التَّکَاثُرُ ۙ﴿۱﴾ ",
      "bn": "বেশি বেশি পাওয়ার প্রতিযোগিতা তোমাদেরকে উদাসীন করে রেখেছে।",
      "words": []
    },
    {
      "ayah_no": 2,
      "arabic": "حَتّٰی زُرۡتُمُ  الۡمَقَابِرَ ؕ﴿۲﴾ ",
      "bn": "যতক্ষণ না তোমরা কবরের দেখা পাবে।",
      "words": []
    },
    {
      "ayah_no": 3,
      "arabic": "کَلَّا  سَوۡفَ تَعۡلَمُوۡنَ ۙ﴿۳﴾ ",
      "bn": "কখনও নয়। অচিরেই তোমরা জানবে।",
      "words": []
    },
    {
      "ayah_no": 4,
      "arabic": "ثُمَّ  کَلَّا سَوۡفَ تَعۡلَمُوۡنَ ؕ﴿۴﴾ ",
      "bn": "আবারও কখনও নয়। অচিরেই তোমরা জানবে",
      "words": []
    },
    {
      "ayah_no": 5,
      "arabic": "کَلَّا لَوۡ تَعۡلَمُوۡنَ عِلۡمَ  الۡیَقِیۡنِ ؕ﴿۵﴾ ",
      "bn": "কখনও নয়। যদি তোমরা দৃঢ় প্রত্যয়ের জ্ঞান জানতে!",
      "words": []
    },
    {
      "ayah_no": 6,
      "arabic": "لَتَرَوُنَّ  الۡجَحِیۡمَ ۙ﴿۶﴾ ",
      "bn": "অবশ্যই তোমরা দেখবে জাহিম।",
      "words": []
    },
    {
      "ayah_no": 7,
      "arabic": "ثُمَّ لَتَرَوُنَّہَا عَیۡنَ الۡیَقِیۡنِ ۙ﴿۷﴾ ",
      "bn": "এরপর অবশ্যই তা তোমরা দেখবে চাক্ষুস প্রত্যয়ে। ",
      "words": []
    },
    {
      "ayah_no": 8,
      "arabic": "ثُمَّ لَتُسۡـَٔلُنَّ یَوۡمَئِذٍ عَنِ النَّعِیۡمِ ٪﴿۸﴾ ",
      "bn": "তারপর সেদিন তোমরা নিয়ামত সম্পর্কে অবশ্যই জিজ্ঞাসিত হবে।",
      "words": []
    }
  ]
}