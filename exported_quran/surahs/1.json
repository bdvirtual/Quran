      "words": []
    },
    {
      "ayah_no": 4,
      "arabic": "مٰلِکِ یَوۡمِ الدِّیۡنِ ؕ﴿۳﴾",
      "bn": "কর্মফল দিনের মালিক।",
      "words": []
    },
    {
      "ayah_no": 5,
      "arabic": "اِیَّاکَ نَعۡبُدُ وَ اِیَّاکَ نَسۡتَعِیۡنُ ؕ﴿۴﴾",
      "bn": "আমরা শুধু আপনার ইবাদত করি আর আমরা  শুধু আপনার কাছে সাহায্য চাই।",
      "words": []
    },
    {
      "ayah_no": 6,
      "arabic": "اِہۡدِ نَا الصِّرَاطَ الۡمُسۡتَقِیۡمَ ۙ﴿۵﴾",
      "bn": "আমাদেরকে সুদৃঢ় পথ দেখান ",
      "words": []
    },
    {
      "ayah_no": 7,
      "arabic": "صِرَاطَ الَّذِیۡنَ اَنۡعَمۡتَ عَلَیۡہِمۡ ۙ۬ غَیۡرِ الۡمَغۡضُوۡبِ عَلَیۡہِمۡ وَ لَا الضَّآلِّیۡنَ ٪﴿۷﴾",
      "bn": "তাদের পথ, যাদের ওপর আপনি অনুগ্রহ করেছেন; নয় তাদের যারা ক্রোধাক্রান্ত, আর না তাদেরও, যারা পথভ্রষ্ট।",
      "words": []
    }
  ]
