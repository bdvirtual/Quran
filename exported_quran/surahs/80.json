{
  "surah_no": 80,
  "ar_name": "عبس",
  "bn_name": "আবাসা",
  "en_name": "'Abasa",
  "ayahs": [
    {
      "ayah_no": 1,
      "arabic": "عَبَسَ وَ تَوَلّٰۤی ۙ﴿۱﴾ ",
      "bn": "সে ভ্রু কুঁচকালো ও মুখ ফিরিয়ে নিল;",
      "words": []
    },
    {
      "ayah_no": 2,
      "arabic": "اَنۡ  جَآءَہُ  الۡاَعۡمٰی ؕ﴿۲﴾ ",
      "bn": "যে, তার কাছে এল অন্ধ লোকটি।",
      "words": []
    },
    {
      "ayah_no": 3,
      "arabic": "وَ  مَا یُدۡرِیۡکَ لَعَلَّہٗ  یَزَّکّٰۤی ۙ﴿۳﴾ ",
      "bn": "এবং কিসে তোমাকে জানাবে? হয়ত সে পরিশুদ্ধ হতো।",
      "words": []
    },
    {
      "ayah_no": 4,
      "arabic": "اَوۡ یَذَّکَّرُ فَتَنۡفَعَہُ  الذِّکۡرٰی  ؕ﴿۴﴾",
      "bn": "অথবা উপদেশ গ্রহণ করত। ফলে উপদেশ তাকে উপকার করত।",
      "words": []
    },
    {
      "ayah_no": 5,
      "arabic": "اَمَّا  مَنِ اسۡتَغۡنٰی ۙ﴿۵﴾ ",
      "bn": "পক্ষান্তরে যে উপেক্ষা করল।",
      "words": []
    },
    {
      "ayah_no": 6,
      "arabic": "فَاَنۡتَ  لَہٗ  تَصَدّٰی ؕ﴿۶﴾ ",
      "bn": "তবুও তুমি তার জন্যই মনোযোগ দিচ্ছ।",
      "words": []
    },
    {
      "ayah_no": 7,
      "arabic": "وَ  مَا عَلَیۡکَ  اَلَّا  یَزَّکّٰی ؕ﴿۷﴾ ",
      "bn": "আর সে পরিশুদ্ধ না হওয়াতে, তোমার দায় নেই।",
      "words": []
    },
    {
      "ayah_no": 8,
      "arabic": "وَ اَمَّا مَنۡ جَآءَکَ یَسۡعٰی ۙ﴿۸﴾ ",
      "bn": "পক্ষান্তরে যে তোমার কাছে ছুটে আসে,",
      "words": []
    },
    {
      "ayah_no": 9,
      "arabic": "وَ ہُوَ  یَخۡشٰی ۙ﴿۹﴾ ",
      "bn": "এবং যে ভয় করে,",
      "words": []
    },
    {
      "ayah_no": 10,
      "arabic": "فَاَنۡتَ عَنۡہُ  تَلَہّٰی ﴿ۚ۱۰﴾ ",
      "bn": "তবুও তুমি তার ক্ষেত্রে অমনোযোগী হচ্ছ।",
      "words": []
    },
    {
      "ayah_no": 11,
      "arabic": "کَلَّاۤ  اِنَّہَا  تَذۡکِرَۃٌ ﴿ۚ۱۱﴾ ",
      "bn": "কখনও নয়, নিশ্চয়ই এটা একটি উপদেশ।",
      "words": []
    },
    {
      "ayah_no": 12,
      "arabic": "فَمَنۡ شَآءَ  ذَکَرَہٗ ﴿ۘ۱۲﴾ ",
      "bn": "অতএব যে চায়, সে তা মনে রাখবে।",
      "words": []
    },
    {
      "ayah_no": 13,
      "arabic": "فِیۡ  صُحُفٍ مُّکَرَّمَۃٍ ﴿ۙ۱۳﴾ ",
      "bn": "সম্মানিত সহীফাগুলোর মধ্যেই;",
      "words": []
    },
    {
      "ayah_no": 14,
      "arabic": "مَّرۡفُوۡعَۃٍ  مُّطَہَّرَۃٍۭ ﴿ۙ۱۴﴾ ",
      "bn": "সমুন্নত, পবিত্র;",
      "words": []
    },
    {
      "ayah_no": 15,
      "arabic": "بِاَیۡدِیۡ سَفَرَۃٍ ﴿ۙ۱۵﴾ ",
      "bn": "এমনসব লেখকদের হাতে;",
      "words": []
    },
    {
      "ayah_no": 16,
      "arabic": "کِرَامٍۭ  بَرَرَۃٍ ﴿ؕ۱۶﴾ ",
      "bn": " সম্মানিত,  পুণ্যবান।",
      "words": []
    },
    {
      "ayah_no": 17,
      "arabic": "قُتِلَ  الۡاِنۡسَانُ مَاۤ  اَکۡفَرَہٗ ﴿ؕ۱۷﴾ ",
      "bn": "ধ্বংস হোক মানুষ! সে কতই না অকৃতজ্ঞ!",
      "words": []
    },
    {
      "ayah_no": 18,
      "arabic": "مِنۡ  اَیِّ  شَیۡءٍ  خَلَقَہٗ ﴿ؕ۱۸﴾ ",
      "bn": "তিনি তাকে কোন পদার্থ থেকে সৃষ্টি করেছেন!",
      "words": []
    },
    {
      "ayah_no": 19,
      "arabic": "مِنۡ  نُّطۡفَۃٍ ؕ خَلَقَہٗ  فَقَدَّرَہٗ ﴿ۙ۱۹﴾ ",
      "bn": "তিনি তাকে নুতফা থেকে সৃষ্টি করেছেন। এরপর তাকে পরিমিতি দিয়েছেন।",
      "words": []
    },
    {
      "ayah_no": 20,
      "arabic": "ثُمَّ السَّبِیۡلَ  یَسَّرَہٗ ﴿ۙ۲۰﴾ ",
      "bn": "তারপর পথ, তিনি তা সহজ করেছেন।",
      "words": []
    },
    {
      "ayah_no": 21,
      "arabic": "ثُمَّ  اَمَاتَہٗ  فَاَقۡبَرَہٗ ﴿ۙ۲۱﴾ ",
      "bn": "এরপর তার মৃত্যু ঘটাবেন, তারপর তাকে সমাহিত করবেন।",
      "words": []
    },
    {
      "ayah_no": 22,
      "arabic": "ثُمَّ  اِذَا شَآءَ  اَنۡشَرَہٗ ﴿ؕ۲۲﴾ ",
      "bn": "তারপর যখন তিনি চাইবেন, তাকে পুনরুত্থিত করবেন।",
      "words": []
    },
    {
      "ayah_no": 23,
      "arabic": "کَلَّا  لَمَّا یَقۡضِ مَاۤ  اَمَرَہٗ ﴿ؕ۲۳﴾ ",
      "bn": "কখনও নয়, সে তা পালন করেনি, যা তিনি তাকে নির্দেশ দিয়েছেন।",
      "words": []
    },
    {
      "ayah_no": 24,
      "arabic": "فَلۡیَنۡظُرِ الۡاِنۡسَانُ  اِلٰی  طَعَامِہٖۤ ﴿ۙ۲۴﴾ ",
      "bn": "সুতরাং মানুষ যেন তার খাদ্যের দিকে লক্ষ করে!",
      "words": []
    },
    {
      "ayah_no": 25,
      "arabic": "اَنَّا صَبَبۡنَا  الۡمَآءَ صَبًّا ﴿ۙ۲۵﴾ ",
      "bn": "নিশ্চয়ই আমরা, আমরাই পানি বর্ষণ করেছি, পর্যাপ্ত বর্ষণ।",
      "words": []
    },
    {
      "ayah_no": 26,
      "arabic": "ثُمَّ شَقَقۡنَا الۡاَرۡضَ شَقًّا ﴿ۙ۲۶﴾ ",
      "bn": "তারপর আমরা ভূমিকে বিদীর্ণ করেছি, সম্পূর্ণ বিদীর্ণ।",
      "words": []
    },
    {
      "ayah_no": 27,
      "arabic": "فَاَنۡۢبَتۡنَا فِیۡہَا حَبًّا ﴿ۙ۲۷﴾ ",
      "bn": "এরপর আমরা তার মধ্যে উৎপন্ন করেছি শস্য;",
      "words": []
    },
    {
      "ayah_no": 28,
      "arabic": "وَّ عِنَبًا وَّ  قَضۡبًا ﴿ۙ۲۸﴾ ",
      "bn": "এবং আঙুর ও শাক—সবজি;",
      "words": []
    },
    {
      "ayah_no": 29,
      "arabic": "وَّ  زَیۡتُوۡنًا وَّ نَخۡلًا ﴿ۙ۲۹﴾ ",
      "bn": "এবং যাইতুন ও খেজুর;",
      "words": []
    },
    {
      "ayah_no": 30,
      "arabic": "وَّ  حَدَآئِقَ غُلۡبًا ﴿ۙ۳۰﴾ ",
      "bn": "এবং ঘন গাছপালা বিশিষ্ট বাগানসমূহ;",
      "words": []
    },
    {
      "ayah_no": 31,
      "arabic": "وَّ  فَاکِہَۃً  وَّ اَبًّا ﴿ۙ۳۱﴾ ",
      "bn": "আর ফলমূল ও তৃণ;",
      "words": []
    },
    {
      "ayah_no": 32,
      "arabic": "مَّتَاعًا  لَّکُمۡ  وَ لِاَنۡعَامِکُمۡ ﴿ؕ۳۲﴾ ",
      "bn": "তোমাদের জন্য ও তোমাদের গৃহপালিত পশুদের জন্য ভোগ্যসামগ্রী হিসাবে।",
      "words": []
    },
    {
      "ayah_no": 33,
      "arabic": "فَاِذَا جَآءَتِ الصَّآخَّۃُ ﴿۫۳۳﴾ ",
      "bn": "এরপর যখন প্রকম্পিত শব্দ আসবে।",
      "words": []
    },
    {
      "ayah_no": 34,
      "arabic": "یَوۡمَ  یَفِرُّ  الۡمَرۡءُ مِنۡ  اَخِیۡہِ ﴿ۙ۳۴﴾ ",
      "bn": "সেদিন মানুষ পালাবে তার ভাই থেকে,",
      "words": []
    },
    {
      "ayah_no": 35,
      "arabic": "وَ اُمِّہٖ  وَ اَبِیۡہِ ﴿ۙ۳۵﴾ ",
      "bn": "এবং তার মা ও তার পিতা, ",
      "words": []
    },
    {
      "ayah_no": 36,
      "arabic": "وَ صَاحِبَتِہٖ  وَ بَنِیۡہِ ﴿ؕ۳۶﴾ ",
      "bn": "আর তার স্ত্রী ও তার সন্তানাদি।",
      "words": []
    },
    {
      "ayah_no": 37,
      "arabic": "لِکُلِّ امۡرِیًٔ مِّنۡہُمۡ یَوۡمَئِذٍ شَاۡنٌ یُّغۡنِیۡہِ ﴿ؕ۳۷﴾ ",
      "bn": "সেদিন তাদের মধ্যকার প্রত্যেক ব্যক্তির জন্যই এমন পরিস্থিতি, যা তাকে ব্যতিব্যস্ত রাখবে।",
      "words": []
    },
    {
      "ayah_no": 38,
      "arabic": "وُجُوۡہٌ  یَّوۡمَئِذٍ مُّسۡفِرَۃٌ ﴿ۙ۳۸﴾",
      "bn": "সেদিন কিছু চেহারা উজ্জ্বল,",
      "words": []
    },
    {
      "ayah_no": 39,
      "arabic": "ضَاحِکَۃٌ  مُّسۡتَبۡشِرَۃٌ ﴿ۚ۳۹﴾ ",
      "bn": "হাস্যোজ্জ্বল, প্রফুল্ল।",
      "words": []
    },
    {
      "ayah_no": 40,
      "arabic": "وَ وُجُوۡہٌ  یَّوۡمَئِذٍ عَلَیۡہَا غَبَرَۃٌ ﴿ۙ۴۰﴾ ",
      "bn": "আর কিছু চেহারা, সেদিন সেগুলোর ওপর থাকবে মলিনতা।",
      "words": []
    },
    {
      "ayah_no": 41,
      "arabic": "تَرۡہَقُہَا قَتَرَۃٌ ﴿ؕ۴۱﴾ ",
      "bn": "সেগুলোকে আচ্ছন্ন করবে কালিমা।",
      "words": []
    },
    {
      "ayah_no": 42,
      "arabic": "اُولٰٓئِکَ ہُمُ الۡکَفَرَۃُ  الۡفَجَرَۃُ ﴿٪۴۲﴾ ",
      "bn": "ওরাই কাফির, পাপী।",
      "words": []
    }
  ]
}