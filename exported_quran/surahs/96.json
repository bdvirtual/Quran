{
  "surah_no": 96,
  "ar_name": "العلق",
  "bn_name": "আল-আলাক",
  "en_name": "Al-'Alaq",
  "ayahs": [
    {
      "ayah_no": 1,
      "arabic": "اِقۡرَاۡ بِاسۡمِ رَبِّکَ الَّذِیۡ خَلَقَ ۚ﴿۱﴾ ",
      "bn": "পড়! তোমার রবের নামে, যিনি সৃষ্টি করেছেন।",
      "words": []
    },
    {
      "ayah_no": 2,
      "arabic": "خَلَقَ الۡاِنۡسَانَ مِنۡ عَلَقٍ ۚ﴿۲﴾ ",
      "bn": "তিনি মানুষকে সৃষ্টি করেছেন আলাক থেকে।",
      "words": []
    },
    {
      "ayah_no": 3,
      "arabic": "اِقۡرَاۡ وَ رَبُّکَ الۡاَکۡرَمُ ۙ﴿۳﴾ ",
      "bn": "পড়! আর তোমার রব মহাসম্মানিত।",
      "words": []
    },
    {
      "ayah_no": 4,
      "arabic": "الَّذِیۡ عَلَّمَ بِالۡقَلَمِ ۙ﴿۴﴾ ",
      "bn": "যিনি শিক্ষা দিয়েছেন কলমের মাধ্যমে।",
      "words": []
    },
    {
      "ayah_no": 5,
      "arabic": "عَلَّمَ الۡاِنۡسَانَ مَا لَمۡ  یَعۡلَمۡ ؕ﴿۵﴾ ",
      "bn": "তিনি মানুষকে শিক্ষা দিয়েছেন, যা সে জানত না।",
      "words": []
    },
    {
      "ayah_no": 6,
      "arabic": "کَلَّاۤ  اِنَّ  الۡاِنۡسَانَ  لَیَطۡغٰۤی ۙ﴿۶﴾ ",
      "bn": "কখনও নয়। নিশ্চয়ই মানুষ অবশ্যই সীমালঙ্ঘন করে।",
      "words": []
    },
    {
      "ayah_no": 7,
      "arabic": "اَنۡ  رَّاٰہُ  اسۡتَغۡنٰی ﴿ؕ۷﴾ ",
      "bn": "এটাও যে, সে নিজেকে দেখে, সে স্বয়ংসম্পূর্ণ হয়ে আছে।",
      "words": []
    },
    {
      "ayah_no": 8,
      "arabic": "اِنَّ  اِلٰی رَبِّکَ  الرُّجۡعٰی ؕ﴿۸﴾ ",
      "bn": "নিশ্চয়ই তোমার রবের দিকেই প্রত্যাবর্তন।",
      "words": []
    },
    {
      "ayah_no": 9,
      "arabic": "اَرَءَیۡتَ الَّذِیۡ یَنۡہٰی ۙ﴿۹﴾ ",
      "bn": "তুমি কি তাকে দেখেছ, যে বাধা দেয়?",
      "words": []
    },
    {
      "ayah_no": 10,
      "arabic": "عَبۡدًا اِذَا صَلّٰی ﴿ؕ۱۰﴾ ",
      "bn": "একজন বান্দাকে, যখন সে সলাত আদায় করে। ",
      "words": []
    },
    {
      "ayah_no": 11,
      "arabic": "اَرَءَیۡتَ  اِنۡ کَانَ عَلَی الۡہُدٰۤی ﴿ۙ۱۱﴾ ",
      "bn": "তুমি কি দেখেছ, যদি সে হিদায়েতের ওপর থাকে!",
      "words": []
    },
    {
      "ayah_no": 12,
      "arabic": "اَوۡ  اَمَرَ  بِالتَّقۡوٰی ﴿ؕ۱۲﴾ ",
      "bn": "বা তাকওয়ার বিষয়ে নির্দেশনা দেয়।",
      "words": []
    },
    {
      "ayah_no": 13,
      "arabic": "اَرَءَیۡتَ  اِنۡ کَذَّبَ وَ تَوَلّٰی ﴿ؕ۱۳﴾ ",
      "bn": "তুমি কি দেখেছ নিশ্চয়ই সে মিথ্যারোপ করেছে ও মুখ ফিরিয়ে নিয়েছে?",
      "words": []
    },
    {
      "ayah_no": 14,
      "arabic": "اَلَمۡ یَعۡلَمۡ بِاَنَّ اللّٰہَ یَرٰی ﴿ؕ۱۴﴾ ",
      "bn": "সে কি এ বিষয়ে জানে না যে, আল্লাহ দেখছেন?",
      "words": []
    },
    {
      "ayah_no": 15,
      "arabic": "کَلَّا لَئِنۡ لَّمۡ یَنۡتَہِ ۬ۙ  لَنَسۡفَعًۢا بِالنَّاصِیَۃِ ﴿ۙ۱۵﴾ ",
      "bn": "কখনও নয়। অবশ্যই যদি সে বিরত না হয়, অবশ্যই আমরা সামনের চুল ধরে হিঁচড়াব;",
      "words": []
    },
    {
      "ayah_no": 16,
      "arabic": "نَاصِیَۃٍ کَاذِبَۃٍ خَاطِئَۃٍ ﴿ۚ۱۶﴾ ",
      "bn": "সামনের চুলওয়ালা মিথ্যুক, অপরাধী।",
      "words": []
    },
    {
      "ayah_no": 17,
      "arabic": "فَلۡیَدۡعُ نَادِیَہٗ ﴿ۙ۱۷﴾ ",
      "bn": "অতএব, সে যেন তার দোসরদেরকে ডাকে।",
      "words": []
    },
    {
      "ayah_no": 18,
      "arabic": "سَنَدۡعُ  الزَّبَانِیَۃَ ﴿ۙ۱۸﴾ ",
      "bn": "শীঘ্রই আমরাও আযাবের প্রহরীদেরকে ডাকব।",
      "words": []
    },
    {
      "ayah_no": 19,
      "arabic": "کَلَّا ؕ لَا تُطِعۡہُ وَ اسۡجُدۡ وَ اقۡتَرِبۡ ﴿٪ٛ۱۹﴾",
      "bn": "কখনও নয়। তুমি ওর অনুসরণ কোরো না। আর সিজদা করো ও নৈকট্য অর্জন করো।",
      "words": []
    }
  ]
}