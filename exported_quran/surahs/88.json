{
  "surah_no": 88,
  "ar_name": "الغاشية",
  "bn_name": "আল-গাশিয়াহ",
  "en_name": "Al-Ghashiyah",
  "ayahs": [
    {
      "ayah_no": 1,
      "arabic": "ہَلۡ  اَتٰىکَ حَدِیۡثُ  الۡغَاشِیَۃِ ؕ﴿۱﴾ ",
      "bn": " তোমার কাছে কি ‘আচ্ছন্নকারী’—এর সংবাদ এসেছে?",
      "words": []
    },
    {
      "ayah_no": 2,
      "arabic": "وُجُوۡہٌ  یَّوۡمَئِذٍ خَاشِعَۃٌ ۙ﴿۲﴾ ",
      "bn": " সেদিন অনেক চেহারা ভীতসন্ত্রস্ত;",
      "words": []
    },
    {
      "ayah_no": 3,
      "arabic": "عَامِلَۃٌ  نَّاصِبَۃٌ ۙ﴿۳﴾",
      "bn": "পরিশ্রান্ত, অবসন্ন।",
      "words": []
    },
    {
      "ayah_no": 4,
      "arabic": "تَصۡلٰی نَارًا حَامِیَۃً ۙ﴿۴﴾ ",
      "bn": "প্রবেশ করবে উত্তপ্ত আগুনে।",
      "words": []
    },
    {
      "ayah_no": 5,
      "arabic": "تُسۡقٰی مِنۡ عَیۡنٍ  اٰنِیَۃٍ ؕ﴿۵﴾ ",
      "bn": "পান করান হবে ফুটন্ত ঝর্ণা থেকে।",
      "words": []
    },
    {
      "ayah_no": 6,
      "arabic": "لَیۡسَ لَہُمۡ طَعَامٌ   اِلَّا مِنۡ ضَرِیۡعٍ ۙ﴿۶﴾ ",
      "bn": "কিছু কাঁটাযুক্ত শুকনা ঘাস ছাড়া তাদের জন্য কোনো খাবার নেই।",
      "words": []
    },
    {
      "ayah_no": 7,
      "arabic": "لَّا یُسۡمِنُ وَ لَا یُغۡنِیۡ مِنۡ جُوۡعٍ ؕ﴿۷﴾ ",
      "bn": "সেটা না দিবে পুষ্টি আর না আসবে ক্ষুধার কাজে।",
      "words": []
    },
    {
      "ayah_no": 8,
      "arabic": "وُجُوۡہٌ  یَّوۡمَئِذٍ نَّاعِمَۃٌ ۙ﴿۸﴾ ",
      "bn": "সেদিন অনেক চেহারা আনন্দোজ্জ্বল,",
      "words": []
    },
    {
      "ayah_no": 9,
      "arabic": "لِّسَعۡیِہَا  رَاضِیَۃٌ ۙ﴿۹﴾ ",
      "bn": "তার প্রচেষ্টার জন্য পরিতৃপ্ত।",
      "words": []
    },
    {
      "ayah_no": 10,
      "arabic": "فِیۡ  جَنَّۃٍ  عَالِیَۃٍ ﴿ۙ۱۰﴾ ",
      "bn": "সুউচ্চ জান্নাতের মধ্যেই; ",
      "words": []
    },
    {
      "ayah_no": 11,
      "arabic": "لَّا تَسۡمَعُ  فِیۡہَا  لَاغِیَۃً ﴿ؕ۱۱﴾ ",
      "bn": "তার মধ্যে শুনবে না অসার কিছু।",
      "words": []
    },
    {
      "ayah_no": 12,
      "arabic": "فِیۡہَا عَیۡنٌ جَارِیَۃٌ ﴿ۘ۱۲﴾ ",
      "bn": "তার মধ্যে আছে প্রবহমান ঝর্ণা;",
      "words": []
    },
    {
      "ayah_no": 13,
      "arabic": "فِیۡہَا سُرُرٌ  مَّرۡفُوۡعَۃٌ ﴿ۙ۱۳﴾ ",
      "bn": "তার মধ্যে আছে উঁচু আসনসমূহ;",
      "words": []
    },
    {
      "ayah_no": 14,
      "arabic": "وَّ  اَکۡوَابٌ مَّوۡضُوۡعَۃٌ ﴿ۙ۱۴﴾ ",
      "bn": "এবং প্রস্তুত পানপাত্রসমূহ;",
      "words": []
    },
    {
      "ayah_no": 15,
      "arabic": "وَّ نَمَارِقُ مَصۡفُوۡفَۃٌ ﴿ۙ۱۵﴾ ",
      "bn": "ও সারি সারি বহু বালিশ;",
      "words": []
    },
    {
      "ayah_no": 16,
      "arabic": "وَّ زَرَابِیُّ  مَبۡثُوۡثَۃٌ ﴿ؕ۱۶﴾ ",
      "bn": "আর বিছানো বহু গালিচা।",
      "words": []
    },
    {
      "ayah_no": 17,
      "arabic": "اَفَلَا یَنۡظُرُوۡنَ  اِلَی الۡاِبِلِ کَیۡفَ خُلِقَتۡ ﴿ٝ۱۷﴾ ",
      "bn": "তবুও কি তারা লক্ষ করে না উটের প্রতি, কিভাবে তা সৃষ্টি করা হয়েছে?",
      "words": []
    },
    {
      "ayah_no": 18,
      "arabic": "وَ  اِلَی السَّمَآءِ کَیۡفَ رُفِعَتۡ ﴿ٝ۱۸﴾ ",
      "bn": "এবং আকাশের দিকে, কীভাবে সেটা উপরে রাখা হয়েছে?",
      "words": []
    },
    {
      "ayah_no": 19,
      "arabic": "وَ  اِلَی الۡجِبَالِ کَیۡفَ نُصِبَتۡ ﴿ٝ۱۹﴾ ",
      "bn": "এবং পাহাড়সমূহের দিকে, কিভাবে সেগুলো স্থাপন করা হয়েছে?",
      "words": []
    },
    {
      "ayah_no": 20,
      "arabic": "وَ  اِلَی الۡاَرۡضِ کَیۡفَ سُطِحَتۡ ﴿ٝ۲۰﴾ ",
      "bn": "এবং ভূমির দিকে, কীভাবে তা বিছানো হয়েছে?",
      "words": []
    },
    {
      "ayah_no": 21,
      "arabic": "فَذَکِّرۡ ۟ؕ  اِنَّمَاۤ  اَنۡتَ مُذَکِّرٌ ﴿ؕ۲۱﴾ ",
      "bn": "অতএব তুমি উপদেশ দাও, প্রকৃতপক্ষে তুমি একজন উপদেশদাতা।",
      "words": []
    },
    {
      "ayah_no": 22,
      "arabic": "لَسۡتَ عَلَیۡہِمۡ  بِمُصَۜیۡطِرٍ ﴿ۙ۲۲﴾ ",
      "bn": "তুমি ওদের ওপর নিয়ন্ত্রক নও।",
      "words": []
    },
    {
      "ayah_no": 23,
      "arabic": "اِلَّا  مَنۡ  تَوَلّٰی  وَ  کَفَرَ ﴿ۙ۲۳﴾ ",
      "bn": "তবে যে মুখ ফিরিয়ে নিবে ও অস্বীকার করবে;",
      "words": []
    },
    {
      "ayah_no": 24,
      "arabic": "فَیُعَذِّبُہُ  اللّٰہُ  الۡعَذَابَ الۡاَکۡبَرَ ﴿ؕ۲۴﴾ ",
      "bn": "তাহলে আল্লাহ তাকে শাস্তি দিবেন, মহাশাস্তি।",
      "words": []
    },
    {
      "ayah_no": 25,
      "arabic": "اِنَّ  اِلَیۡنَاۤ  اِیَابَہُمۡ ﴿ۙ۲۵﴾ ",
      "bn": "নিশ্চয়ই আমাদের দিকেই তাদের প্রত্যাবর্তন।",
      "words": []
    },
    {
      "ayah_no": 26,
      "arabic": "ثُمَّ  اِنَّ  عَلَیۡنَا حِسَابَہُمۡ ﴿٪۲۶﴾ ",
      "bn": "তারপর নিশ্চয়ই তাদের হিসাবগ্রহণ আমাদের ওপরই।",
      "words": []
    }
  ]
}