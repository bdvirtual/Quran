{
  "surah_no": 87,
  "ar_name": "الأعلى",
  "bn_name": "আল-আলা",
  "en_name": "Al-A'la",
  "ayahs": [
    {
      "ayah_no": 1,
      "arabic": "سَبِّحِ اسۡمَ رَبِّکَ الۡاَعۡلَی ۙ﴿۱﴾ ",
      "bn": "তুমি তাসবীহ করো তোমার সুউচ্চ রবের নামে।",
      "words": []
    },
    {
      "ayah_no": 2,
      "arabic": "الَّذِیۡ خَلَقَ فَسَوّٰی ۪ۙ﴿۲﴾ ",
      "bn": "যিনি সৃষ্টি করেছেন, এরপর সুবিন্যস্ত করেছেন।",
      "words": []
    },
    {
      "ayah_no": 3,
      "arabic": "وَ الَّذِیۡ  قَدَّرَ فَہَدٰی ۪ۙ﴿۳﴾ ",
      "bn": "আর যিনি নির্ধারণ করেছেন। এরপর হিদায়েত দিয়েছেন।",
      "words": []
    },
    {
      "ayah_no": 4,
      "arabic": "وَ الَّذِیۡۤ  اَخۡرَجَ  الۡمَرۡعٰی ۪ۙ﴿۴﴾ ",
      "bn": "এবং যিনি তরুলতা উৎপন্ন করেছেন।",
      "words": []
    },
    {
      "ayah_no": 5,
      "arabic": "فَجَعَلَہٗ  غُثَآءً  اَحۡوٰی ؕ﴿۵﴾ ",
      "bn": "তারপর তা কালো আবর্জনায় পরিণত করেছেন।",
      "words": []
    },
    {
      "ayah_no": 6,
      "arabic": "سَنُقۡرِئُکَ فَلَا تَنۡسٰۤی ۙ﴿۶﴾ ",
      "bn": "অচিরেই আমরা তোমাকে পাঠ করাব; ফলে তুমি ভুলবে না,",
      "words": []
    },
    {
      "ayah_no": 7,
      "arabic": "اِلَّا  مَا شَآءَ اللّٰہُ ؕ اِنَّہٗ  یَعۡلَمُ الۡجَہۡرَ  وَ مَا یَخۡفٰی ؕ﴿۷﴾ ",
      "bn": "আল্লাহ যা চান তা ছাড়া। নিশ্চয়ই তিনি জানেন প্রকাশ্য ও যা গোপন আছে।",
      "words": []
    },
    {
      "ayah_no": 8,
      "arabic": "وَ نُیَسِّرُکَ لِلۡیُسۡرٰی ۚ﴿ۖ۸﴾ ",
      "bn": "আর আমরা সহজ করে দিব তোমার জন্য সহজকে।",
      "words": []
    },
    {
      "ayah_no": 9,
      "arabic": "فَذَکِّرۡ  اِنۡ  نَّفَعَتِ الذِّکۡرٰی ؕ﴿۹﴾ ",
      "bn": "সুতরাং তুমি উপদেশ দাও, যদি উপদেশ উপকারী হয়।",
      "words": []
    },
    {
      "ayah_no": 10,
      "arabic": "سَیَذَّکَّرُ مَنۡ یَّخۡشٰی ﴿ۙ۱۰﴾ ",
      "bn": "যে ভয় করে শীঘ্রই সে উপদেশ গ্রহণ করবে।",
      "words": []
    },
    {
      "ayah_no": 11,
      "arabic": "وَ  یَتَجَنَّبُہَا الۡاَشۡقَی  ﴿ۙ۱۱﴾",
      "bn": "আর হতভাগারাই তা উপেক্ষা করবে,",
      "words": []
    },
    {
      "ayah_no": 12,
      "arabic": "الَّذِیۡ  یَصۡلَی النَّارَ الۡکُبۡرٰی ﴿ۚ۱۲﴾ ",
      "bn": "যে ভয়াবহ আগুনে প্রবেশ করবে।",
      "words": []
    },
    {
      "ayah_no": 13,
      "arabic": "ثُمَّ  لَا یَمُوۡتُ فِیۡہَا وَ لَا یَحۡیٰی ﴿ؕ۱۳﴾ ",
      "bn": "এরপর তার মধ্যে না মারা যাবে, আর না বাঁচবে।",
      "words": []
    },
    {
      "ayah_no": 14,
      "arabic": "قَدۡ  اَفۡلَحَ  مَنۡ  تَزَکّٰی ﴿ۙ۱۴﴾ ",
      "bn": "অবশ্যই সে সাফল্য পেল, যে পরিশুদ্ধ হলো।",
      "words": []
    },
    {
      "ayah_no": 15,
      "arabic": "وَ ذَکَرَ اسۡمَ رَبِّہٖ فَصَلّٰی ﴿ؕ۱۵﴾ ",
      "bn": "এবং তার রবের নাম স্মরণ করল, এরপর সলাত করল। ",
      "words": []
    },
    {
      "ayah_no": 16,
      "arabic": "بَلۡ  تُؤۡثِرُوۡنَ الۡحَیٰوۃَ  الدُّنۡیَا ﴿۫ۖ۱۶﴾ ",
      "bn": "বরং তোমরা দুনিয়ার জীবনকে প্রাধান্য দিচ্ছ।",
      "words": []
    },
    {
      "ayah_no": 17,
      "arabic": "وَ الۡاٰخِرَۃُ  خَیۡرٌ  وَّ اَبۡقٰی ﴿ؕ۱۷﴾ ",
      "bn": "অথচ আখিরাতই উত্তম ও চিরস্থায়ী।",
      "words": []
    },
    {
      "ayah_no": 18,
      "arabic": "اِنَّ ہٰذَا  لَفِی الصُّحُفِ الۡاُوۡلٰی ﴿ۙ۱۸﴾ ",
      "bn": "নিশ্চয়ই এটা অবশ্যই পূর্ববর্তী সহীফাগুলোর মধ্যে রয়েছে",
      "words": []
    },
    {
      "ayah_no": 19,
      "arabic": "صُحُفِ اِبۡرٰہِیۡمَ وَ مُوۡسٰی ﴿٪۱۹﴾",
      "bn": "ইবরাহীম ও মূসার সহীফাসমূহে।",
      "words": []
    }
  ]
}