{
  "surah_no": 100,
  "ar_name": "العاديات",
  "bn_name": "আল-আদিয়াত",
  "en_name": "Al-'Adiyat",
  "ayahs": [
    {
      "ayah_no": 1,
      "arabic": "وَ الۡعٰدِیٰتِ ضَبۡحًا ۙ﴿۱﴾ ",
      "bn": "শপথ ঊর্ধ্বশ্বাসে ধাবমানের।",
      "words": []
    },
    {
      "ayah_no": 2,
      "arabic": "فَالۡمُوۡرِیٰتِ قَدۡحًا ۙ﴿۲﴾ ",
      "bn": "তারপর ঘর্ষণের মাধ্যমে যেগুলো বিচ্ছুরণ সৃষ্টিকারী।",
      "words": []
    },
    {
      "ayah_no": 3,
      "arabic": "فَالۡمُغِیۡرٰتِ صُبۡحًا ۙ﴿۳﴾ ",
      "bn": "তারপর যেগুলো প্রভাতে হামলাকারী।",
      "words": []
    },
    {
      "ayah_no": 4,
      "arabic": "فَاَثَرۡنَ بِہٖ نَقۡعًا ۙ﴿۴﴾ ",
      "bn": "এরপর সেগুলো তা দ্বারা ধুলাবালি উড়ায়।",
      "words": []
    },
    {
      "ayah_no": 5,
      "arabic": "فَوَسَطۡنَ بِہٖ جَمۡعًا ۙ﴿۵﴾ ",
      "bn": "তারপর তাকে নিয়ে একত্রে ভিতরে ঢুকে পড়ে।",
      "words": []
    },
    {
      "ayah_no": 6,
      "arabic": "اِنَّ  الۡاِنۡسَانَ لِرَبِّہٖ  لَکَنُوۡدٌ ۚ﴿۶﴾ ",
      "bn": "নিশ্চয়ই মানুষ তার রবের প্রতি অবশ্যই অকৃতজ্ঞ।",
      "words": []
    },
    {
      "ayah_no": 7,
      "arabic": "وَ  اِنَّہٗ  عَلٰی ذٰلِکَ لَشَہِیۡدٌ ۚ﴿۷﴾ ",
      "bn": "আর সে তো অবশ্যই সেই বিষয়ে সাক্ষী।",
      "words": []
    },
    {
      "ayah_no": 8,
      "arabic": "وَ  اِنَّہٗ  لِحُبِّ الۡخَیۡرِ  لَشَدِیۡدٌ ؕ﴿۸﴾ ",
      "bn": "এবং নিশ্চয়ই সে শ্রেষ্ঠত্বের মোহে অবশ্যই প্রবল।",
      "words": []
    },
    {
      "ayah_no": 9,
      "arabic": "اَفَلَا یَعۡلَمُ  اِذَا بُعۡثِرَ مَا فِی الۡقُبُوۡرِ ۙ﴿۹﴾ ",
      "bn": "তবে কি সে জানে না, কবরগুলোর মধ্যে যা রয়েছে যখন তা উঠানো হবে?",
      "words": []
    },
    {
      "ayah_no": 10,
      "arabic": "وَ  حُصِّلَ مَا فِی الصُّدُوۡرِ ﴿ۙ۱۰﴾ ",
      "bn": "এবং অন্তরগুলোর মধ্যে যা রয়েছে তা প্রকাশিত হবে।",
      "words": []
    },
    {
      "ayah_no": 11,
      "arabic": "اِنَّ  رَبَّہُمۡ  بِہِمۡ یَوۡمَئِذٍ لَّخَبِیۡرٌ ٪﴿۱۱﴾ ",
      "bn": "নিশ্চয়ই সেদিন তাদের রব তাদের সম্পর্কে অবশ্যই বিস্তৃত জ্ঞানসম্পন্ন।",
      "words": []
    }
  ]
}