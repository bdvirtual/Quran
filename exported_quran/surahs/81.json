{
  "surah_no": 81,
  "ar_name": "التكوير",
  "bn_name": "আত-তাকভীর",
  "en_name": "At-Takwir",
  "ayahs": [
    {
      "ayah_no": 1,
      "arabic": "اِذَا  الشَّمۡسُ کُوِّرَتۡ ۪ۙ﴿۱﴾ ",
      "bn": "যখন সূর্য আলোশূন্য হবে।",
      "words": []
    },
    {
      "ayah_no": 2,
      "arabic": "وَ  اِذَا  النُّجُوۡمُ  انۡکَدَرَتۡ ۪ۙ﴿۲﴾ ",
      "bn": "এবং যখন নক্ষত্ররাজি বিক্ষিপ্ত হবে।",
      "words": []
    },
    {
      "ayah_no": 3,
      "arabic": "وَ  اِذَا  الۡجِبَالُ سُیِّرَتۡ ۪ۙ﴿۳﴾ ",
      "bn": "এবং যখন পাহাড়গুলো চলমান হবে।",
      "words": []
    },
    {
      "ayah_no": 4,
      "arabic": "وَ  اِذَا الۡعِشَارُ عُطِّلَتۡ ۪ۙ﴿۴﴾ ",
      "bn": "এবং যখন দশমাসী উপেক্ষিত হবে।",
      "words": []
    },
    {
      "ayah_no": 5,
      "arabic": "وَ  اِذَا  الۡوُحُوۡشُ حُشِرَتۡ ۪ۙ﴿۵﴾ ",
      "bn": "এবং যখন বন্যপশুদের একত্র করা হবে।",
      "words": []
    },
    {
      "ayah_no": 6,
      "arabic": "وَ  اِذَا  الۡبِحَارُ سُجِّرَتۡ ۪ۙ﴿۶﴾ ",
      "bn": "আর যখন সমুদ্রগুলো জ্বালিয়ে দেয়া হবে।",
      "words": []
    },
    {
      "ayah_no": 7,
      "arabic": "وَ  اِذَا النُّفُوۡسُ زُوِّجَتۡ ۪ۙ﴿۷﴾ ",
      "bn": "আর যখন আত্মাগুলোকে সংযোজন করা হবে।",
      "words": []
    },
    {
      "ayah_no": 8,
      "arabic": "وَ  اِذَا  الۡمَوۡءٗدَۃُ  سُئِلَتۡ ۪ۙ﴿۸﴾ ",
      "bn": "আর যখন জীবন্ত কবর দেয়া কন্যাকে জিজ্ঞাসা করা হবে;",
      "words": []
    },
    {
      "ayah_no": 9,
      "arabic": "بِاَیِّ ذَنۡۢبٍ قُتِلَتۡ ۚ﴿۹﴾ ",
      "bn": "কোন অপরাধের কারণে তাকে হত্যা করা হয়েছে!",
      "words": []
    },
    {
      "ayah_no": 10,
      "arabic": "وَ  اِذَا الصُّحُفُ نُشِرَتۡ ﴿۪ۙ۱۰﴾ ",
      "bn": "আর যখন নথিপত্র প্রকাশ করা হবে।",
      "words": []
    },
    {
      "ayah_no": 11,
      "arabic": "وَ اِذَا  السَّمَآءُ کُشِطَتۡ ﴿۪ۙ۱۱﴾ ",
      "bn": "আর যখন আকাশকে উন্মুক্ত করা হবে।",
      "words": []
    },
    {
      "ayah_no": 12,
      "arabic": "وَ  اِذَا  الۡجَحِیۡمُ سُعِّرَتۡ ﴿۪ۙ۱۲﴾ ",
      "bn": "আর যখন জাহিমকে উস্কে দেয়া হবে।",
      "words": []
    },
    {
      "ayah_no": 13,
      "arabic": "وَ  اِذَا  الۡجَنَّۃُ   اُزۡلِفَتۡ ﴿۪ۙ۱۳﴾ ",
      "bn": "আর যখন জান্নাতকে নিকটবর্তী  করা হবে।",
      "words": []
    },
    {
      "ayah_no": 14,
      "arabic": "عَلِمَتۡ نَفۡسٌ مَّاۤ  اَحۡضَرَتۡ ﴿ؕ۱۴﴾ ",
      "bn": "প্রাণ জানতে পারবে, সে যা উপস্থিত করেছে।",
      "words": []
    },
    {
      "ayah_no": 15,
      "arabic": "فَلَاۤ  اُقۡسِمُ  بِالۡخُنَّسِ ﴿ۙ۱۵﴾ ",
      "bn": "সুতরাং না, আমি শপথ করছি আত্মগোপনকারীর।",
      "words": []
    },
    {
      "ayah_no": 16,
      "arabic": "الۡجَوَارِ الۡکُنَّسِ ﴿ۙ۱۶﴾ ",
      "bn": "চলমান, অদৃশ্য।",
      "words": []
    },
    {
      "ayah_no": 17,
      "arabic": "وَ  الَّیۡلِ  اِذَا عَسۡعَسَ ﴿ۙ۱۷﴾ ",
      "bn": "শপথ রাতের, যখন তা শেষ হয়।",
      "words": []
    },
    {
      "ayah_no": 18,
      "arabic": "وَ الصُّبۡحِ  اِذَا تَنَفَّسَ ﴿ۙ۱۸﴾ ",
      "bn": "শপথ প্রভাতের, যখন তা শ্বাস নেয়।",
      "words": []
    },
    {
      "ayah_no": 19,
      "arabic": "اِنَّہٗ  لَقَوۡلُ رَسُوۡلٍ  کَرِیۡمٍ ﴿ۙ۱۹﴾ ",
      "bn": "সেটা তো অবশ্যই সম্মানিত বার্তাবাহকের কথা।",
      "words": []
    },
    {
      "ayah_no": 20,
      "arabic": "ذِیۡ  قُوَّۃٍ  عِنۡدَ ذِی الۡعَرۡشِ مَکِیۡنٍ ﴿ۙ۲۰﴾ ",
      "bn": "শক্তির অধিকারী, আরশের মালিকের কাছে মর্যাদাসম্পন্ন,",
      "words": []
    },
    {
      "ayah_no": 21,
      "arabic": "مُّطَاعٍ  ثَمَّ  اَمِیۡنٍ ﴿ؕ۲۱﴾  ",
      "bn": "অনুসরণীয়, সেখানে বিশ্বস্ত।",
      "words": []
    },
    {
      "ayah_no": 22,
      "arabic": "وَ مَا صَاحِبُکُمۡ بِمَجۡنُوۡنٍ ﴿ۚ۲۲﴾ ",
      "bn": "আর তোমাদের সঙ্গী উন্মাদ নয়।",
      "words": []
    },
    {
      "ayah_no": 23,
      "arabic": "وَ لَقَدۡ رَاٰہُ  بِالۡاُفُقِ الۡمُبِیۡنِ ﴿ۚ۲۳﴾ ",
      "bn": "আর সে অবশ্যই তাকে স্পষ্ট দিগন্তে দেখেছে।",
      "words": []
    },
    {
      "ayah_no": 24,
      "arabic": "وَ مَا ہُوَ عَلَی الۡغَیۡبِ بِضَنِیۡنٍ ﴿ۚ۲۴﴾ ",
      "bn": "আর সে গাইবের বিষয়ে কৃপণ নয়।",
      "words": []
    },
    {
      "ayah_no": 25,
      "arabic": "وَ مَا ہُوَ بِقَوۡلِ شَیۡطٰنٍ رَّجِیۡمٍ ﴿ۙ۲۵﴾ ",
      "bn": "এবং সেটা বিতাড়িত শয়তানের কথাও নয়।",
      "words": []
    },
    {
      "ayah_no": 26,
      "arabic": "فَاَیۡنَ تَذۡہَبُوۡنَ ﴿ؕ۲۶﴾ ",
      "bn": "এরপরও তোমরা কোথায় যাচ্ছ!",
      "words": []
    },
    {
      "ayah_no": 27,
      "arabic": "اِنۡ  ہُوَ  اِلَّا ذِکۡرٌ  لِّلۡعٰلَمِیۡنَ ﴿ۙ۲۷﴾ ",
      "bn": "সেটা তো জগতসমূহের জন্য কেবলই উপদেশ।",
      "words": []
    },
    {
      "ayah_no": 28,
      "arabic": "لِمَنۡ  شَآءَ مِنۡکُمۡ  اَنۡ یَّسۡتَقِیۡمَ ﴿ؕ۲۸﴾ ",
      "bn": "তার জন্য, তোমাদের মধ্য থেকে যে সুদৃঢ় থাকতে চায়।",
      "words": []
    },
    {
      "ayah_no": 29,
      "arabic": "وَ مَا تَشَآءُوۡنَ  اِلَّاۤ  اَنۡ یَّشَآءَ اللّٰہُ  رَبُّ الۡعٰلَمِیۡنَ ﴿٪۲۹﴾ ",
      "bn": "আর তোমরা ইচ্ছা করতে পারো না, জগতসমূহের রব আল্লাহর ইচ্ছা করা ব্যতিত। ",
      "words": []
    }
  ]
}