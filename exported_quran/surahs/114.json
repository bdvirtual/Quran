      "arabic": "قُلۡ  اَعُوۡذُ  بِرَبِّ النَّاسِ ۙ﴿۱﴾ ",
      "bn": "বলো! আমি আশ্রয় চাচ্ছি মানুষের রবের কাছে।",
      "words": []
    },
    {
      "ayah_no": 2,
      "arabic": "مَلِکِ النَّاسِ ۙ﴿۲﴾ ",
      "bn": "মানুষের মালিক।",
      "words": []
    },
    {
      "ayah_no": 3,
      "arabic": "اِلٰہِ  النَّاسِ ۙ﴿۳﴾ ",
      "bn": "মানুষের ইলাহ।",
      "words": []
    },
    {
      "ayah_no": 4,
      "arabic": "مِنۡ  شَرِّ الۡوَسۡوَاسِ ۬ۙ  الۡخَنَّاسِ ۪ۙ﴿۴﴾ ",
      "bn": "প্ররোচনাদানকারী আত্মগোপনকারীর অনিষ্ট থেকে। ",
      "words": []
    },
    {
      "ayah_no": 5,
      "arabic": "الَّذِیۡ یُوَسۡوِسُ فِیۡ صُدُوۡرِ النَّاسِ ۙ﴿۵﴾ ",
      "bn": "যে মানুষের অন্তরসমূহের মধ্যে প্ররোচনা দেয়।",
      "words": []
    },
    {
      "ayah_no": 6,
      "arabic": "مِنَ الۡجِنَّۃِ وَ النَّاسِ ٪﴿۶﴾ ",
      "bn": "জ্বীন ও মানুষের মধ্য থেকে।",
      "words": []
    }
