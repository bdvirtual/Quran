{
  "surah_no": 101,
  "ar_name": "القارعة",
  "bn_name": "আল-কারিআহ",
  "en_name": "Al-Qari'ah",
  "ayahs": [
    {
      "ayah_no": 1,
      "arabic": "اَلۡقَارِعَۃُ ۙ﴿۱﴾ ",
      "bn": "প্রলয়সংকেত ",
      "words": []
    },
    {
      "ayah_no": 2,
      "arabic": "مَا الۡقَارِعَۃُ ۚ﴿۲﴾ ",
      "bn": "প্রলয়সংকেত কী?",
      "words": []
    },
    {
      "ayah_no": 3,
      "arabic": "وَ  مَاۤ  اَدۡرٰىکَ مَا الۡقَارِعَۃُ ؕ﴿۳﴾ ",
      "bn": "আর কিসে তোমাকে জানাবে, প্রলয়সংকেত কী?",
      "words": []
    },
    {
      "ayah_no": 4,
      "arabic": "یَوۡمَ یَکُوۡنُ  النَّاسُ کَالۡفَرَاشِ الۡمَبۡثُوۡثِ ۙ﴿۴﴾ ",
      "bn": "যেদিন মানুষ বিক্ষিপ্ত পতঙ্গের মতো হবে।",
      "words": []
    },
    {
      "ayah_no": 5,
      "arabic": "وَ تَکُوۡنُ  الۡجِبَالُ کَالۡعِہۡنِ الۡمَنۡفُوۡشِ ؕ﴿۵﴾",
      "bn": "এবং পাহাড়গুলো হবে ধুনিত পশমের মতো।",
      "words": []
    },
    {
      "ayah_no": 6,
      "arabic": "فَاَمَّا  مَنۡ  ثَقُلَتۡ مَوَازِیۡنُہٗ ۙ﴿۶﴾ ",
      "bn": "তবে সে, যার পাল্লা ভারী হবে।",
      "words": []
    },
    {
      "ayah_no": 7,
      "arabic": "فَہُوَ  فِیۡ عِیۡشَۃٍ  رَّاضِیَۃٍ ؕ﴿۷﴾ ",
      "bn": "তাহলে সে সন্তোষজনক জীবন—যাপনের মধ্যে থাকবে।",
      "words": []
    },
    {
      "ayah_no": 8,
      "arabic": "وَ اَمَّا مَنۡ خَفَّتۡ مَوَازِیۡنُہٗ ۙ﴿۸﴾ ",
      "bn": "পক্ষান্তরে সে, যার পাল্লা হালকা হবে।",
      "words": []
    },
    {
      "ayah_no": 9,
      "arabic": "فَاُمُّہٗ  ہَاوِیَۃٌ ؕ﴿۹﴾ ",
      "bn": "তাহলে তার ঠিকানা হাবিয়া।",
      "words": []
    },
    {
      "ayah_no": 10,
      "arabic": "وَ مَاۤ  اَدۡرٰىکَ مَا ہِیَہۡ ﴿ؕ۱۰﴾ ",
      "bn": "আর কিসে তোমাকে জানাবে, সেটা কী?",
      "words": []
    },
    {
      "ayah_no": 11,
      "arabic": "نَارٌ حَامِیَۃٌ ﴿٪۱۱﴾ ",
      "bn": "উত্তপ্ত আগুন।",
      "words": []
    }
  ]
}