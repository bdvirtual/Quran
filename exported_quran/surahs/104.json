{
  "surah_no": 104,
  "ar_name": "الهمزة",
  "bn_name": "আল-হুমাযাহ",
  "en_name": "Al-Humazah",
  "ayahs": [
    {
      "ayah_no": 1,
      "arabic": "وَیۡلٌ   لِّکُلِّ ہُمَزَۃٍ   لُّمَزَۃِۣ ۙ﴿۱﴾",
      "bn": "সামনে নিন্দাকারীর, পিছনে দোষ প্রচারকারীর প্রত্যেকের জন্য ওয়াইল।",
      "words": []
    },
    {
      "ayah_no": 2,
      "arabic": "الَّذِیۡ جَمَعَ  مَالًا  وَّ عَدَّدَہٗ ۙ﴿۲﴾ ",
      "bn": "যে সম্পদ জমা করে এবং তা বারবার গণনা করে।",
      "words": []
    },
    {
      "ayah_no": 3,
      "arabic": "یَحۡسَبُ اَنَّ مَالَہٗۤ  اَخۡلَدَہٗ ۚ﴿۳﴾ ",
      "bn": "সে ধারণা করে যে, তার সম্পদ তাকে অমর করে রাখবে।",
      "words": []
    },
    {
      "ayah_no": 4,
      "arabic": "کَلَّا  لَیُنۡۢبَذَنَّ فِی الۡحُطَمَۃِ ۫﴿ۖ۴﴾ ",
      "bn": "কখনও নয়। অবশ্যই তাকে হুতামার মধ্যে নিক্ষেপ করা হবে।",
      "words": []
    },
    {
      "ayah_no": 5,
      "arabic": "وَ  مَاۤ  اَدۡرٰىکَ مَا  الۡحُطَمَۃُ ؕ﴿۵﴾ ",
      "bn": "আর কিসে তোমাকে জানাবে, হুতামা কী?",
      "words": []
    },
    {
      "ayah_no": 6,
      "arabic": "نَارُ اللّٰہِ الۡمُوۡقَدَۃُ ۙ﴿۶﴾ ",
      "bn": "আল্লাহর আগুন, প্রজ্জ্বলিত।",
      "words": []
    },
    {
      "ayah_no": 7,
      "arabic": "الَّتِیۡ  تَطَّلِعُ  عَلَی الۡاَفۡـِٕدَۃِ ؕ﴿۷﴾ ",
      "bn": "যা হৃদয়সমূহে পৌঁছে যাবে।",
      "words": []
    },
    {
      "ayah_no": 8,
      "arabic": "اِنَّہَا عَلَیۡہِمۡ  مُّؤۡصَدَۃٌ ۙ﴿۸﴾ ",
      "bn": "নিশ্চয়ই সেটা তাদের ওপর আবদ্ধ।",
      "words": []
    },
    {
      "ayah_no": 9,
      "arabic": "فِیۡ  عَمَدٍ  مُّمَدَّدَۃٍ ٪﴿۹﴾ ",
      "bn": "দীর্ঘ স্তম্ভসমূহের মধ্যে।",
      "words": []
    }
  ]
}