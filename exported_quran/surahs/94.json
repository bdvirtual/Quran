{
  "surah_no": 94,
  "ar_name": "الشرح",
  "bn_name": "আশ-শারহ",
  "en_name": "Ash-Sharh",
  "ayahs": [
    {
      "ayah_no": 1,
      "arabic": "اَلَمۡ نَشۡرَحۡ  لَکَ صَدۡرَکَ ۙ﴿۱﴾ ",
      "bn": "আমরা কি তোমার জন্য তোমার অন্তর উন্মুক্ত করিনি?",
      "words": []
    },
    {
      "ayah_no": 2,
      "arabic": "وَ وَضَعۡنَا عَنۡکَ وِزۡرَکَ ۙ﴿۲﴾ ",
      "bn": "এবং তোমার থেকে আমরা তোমার বোঝা নামিয়েছি।",
      "words": []
    },
    {
      "ayah_no": 3,
      "arabic": "الَّذِیۡۤ  اَنۡقَضَ ظَہۡرَکَ ۙ﴿۳﴾ ",
      "bn": "যা তোমার পিঠ ভেঙে দিচ্ছিল। ",
      "words": []
    },
    {
      "ayah_no": 4,
      "arabic": "وَ رَفَعۡنَا لَکَ ذِکۡرَکَ ؕ﴿۴﴾ ",
      "bn": "এবং আমরা তোমার জন্য তোমার স্মরণকে সুউচ্চ করেছি।",
      "words": []
    },
    {
      "ayah_no": 5,
      "arabic": "فَاِنَّ مَعَ الۡعُسۡرِ  یُسۡرًا ۙ﴿۵﴾ ",
      "bn": "তবে নিশ্চয়ই কষ্টের সাথেই স্বস্তি।",
      "words": []
    },
    {
      "ayah_no": 6,
      "arabic": "اِنَّ مَعَ الۡعُسۡرِ  یُسۡرًا ؕ﴿۶﴾ ",
      "bn": "নিশ্চয়ই কষ্টের সাথেই স্বস্তি।",
      "words": []
    },
    {
      "ayah_no": 7,
      "arabic": "فَاِذَا  فَرَغۡتَ فَانۡصَبۡ ۙ﴿۷﴾ ",
      "bn": "সুতরাং তুমি যখন অবসর হও, তখন সাধনা করো।",
      "words": []
    },
    {
      "ayah_no": 8,
      "arabic": "وَ اِلٰی  رَبِّکَ فَارۡغَبۡ ٪﴿۸﴾ ",
      "bn": "আর তোমার রবের প্রতি তখন তুমি মনোনিবেশ করো।",
      "words": []
    }
  ]
}