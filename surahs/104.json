  "ayahs": [
    {
      "ayah_no": 1,
      "arabic": "وَیلٌ لِّکُلِّ ہُمَزَۃٍ لُّمَزَۃِ",
      "bn": "সামনে নিন্দাকারীর, পিছনে দোষ প্রচারকারীর প্রত্যেকের জন্য ওয়াইল।",
      "words": [
        {
          "ar": "وَیۡلٌ",
          "bn": "ওয়াইল"
        },
        {
          "ar": "لِّکُلِّ",
          "bn": "প্রত্যেকের জন্য"
        },
        {
          "ar": "ہُمَزَۃٍ",
          "bn": "সামনে নিন্দাকারীর"
        },
        {
          "ar": "لُّمَزَۃِۣ",
          "bn": "পিছনে দোষ প্রচারকারীর"
        }
      ]
    },
    {
      "ayah_no": 2,
      "arabic": "الَّذِی جَمَعَ مَالًا وَّ عَدَّدَہٗ",
      "bn": "যে সম্পদ জমা করে এবং তা বারবার গণনা করে।",
      "words": [
        {
          "ar": "الَّذِیۡ",
          "bn": "যে "
        },
        {
          "ar": "جَمَعَ",
          "bn": "জমা করে"
        },
        {
          "ar": "مَالًا",
          "bn": "সম্পদ "
        },
        {
          "ar": "وَّ عَدَّدَہٗ",
          "bn": "এবং তা বারবার গণনা করে"
        }
      ]
    },
    {
      "ayah_no": 3,
      "arabic": "یَحسَبُ اَنَّ مَالَہٗ اَخلَدَہٗ",
      "bn": "সে ধারণা করে যে, তার সম্পদ তাকে অমর করে রাখবে।",
      "words": [
        {
          "ar": "یَحۡسَبُ",
          "bn": "সে ধারণা করে"
        },
        {
          "ar": "اَنَّ",
          "bn": "যে"
        },
        {
          "ar": "مَالَہٗۤ",
          "bn": "তার সম্পদ"
        },
        {
          "ar": "اَخۡلَدَہٗ",
          "bn": "তাকে অমর করে রাখবে"
        }
      ]
    },
    {
      "ayah_no": 4,
      "arabic": "کَلَّا لَیُنبَذَنَّ فِی الحُطَمَۃِ",
      "bn": "কখনও নয়। অবশ্যই তাকে হুতামার মধ্যে নিক্ষেপ করা হবে।",
      "words": [
