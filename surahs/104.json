          "ar": "کَلَّا",
          "bn": "কখনও নয়"
        },
        {
          "ar": "لَیُنۡۢبَذَنَّ",
          "bn": "অবশ্যই তাকে নিক্ষেপ করা হবে"
        },
        {
          "ar": "فِی",
          "bn": "মধ্যে"
        },
        {
          "ar": "الۡحُطَمَۃِ",
          "bn": "হুতামার"
        }
      ]
    },
    {
      "ayah_no": 5,
      "arabic": "وَ مَا اَدرٰىکَ مَا الحُطَمَۃُ ؕ",
      "bn": "আর কিসে তোমাকে জানাবে, হুতামা কী?",
      "words": [
